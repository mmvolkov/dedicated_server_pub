# ═══════════════════════════════════════════════════════════════
#  Inference Stack — Вариант D (Production)
#  Скопируйте в .env и заполните значения
# ═══════════════════════════════════════════════════════════════

# Домен (все сервисы будут на поддоменах)
# ai.example.com, n8n.example.com, app.example.com, qdrant.example.com
DOMAIN=example.com

# Let's Encrypt — email для SSL-сертификатов
ACME_EMAIL=admin@example.com

# Traefik Dashboard — BasicAuth (сгенерировать: htpasswd -nb admin password)
TRAEFIK_AUTH=admin:$$apr1$$xyz$$hashedpassword

# PostgreSQL
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me-strong-password-123

# n8n
N8N_ENCRYPTION_KEY=change-me-random-32-char-string-here

# Qdrant API Key (опционально, но рекомендуется для production)
QDRANT_API_KEY=change-me-qdrant-key

# HuggingFace Token (для gated-моделей, если потребуется)
HF_TOKEN=
